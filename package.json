{
  "name": "ui-test-automation-framework",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "type": "commonjs",
  "scripts": {
    "test:tag": "cucumber-js --tags",
    "test:e2e": "cucumber-js",
    "test:e2e:ui": "HEADLESS=false cucumber-js --format @cucumber/pretty-formatter",
    "test:unit": "mocha --require ts-node/register 'src/tests/**/*.test.ts'",
    "lint": "eslint src/**/*.ts",
    "format": "prettier --write src/**/*.ts",
    "install:playwright": "playwright install",
    "install:playwright:browsers": "playwright install --with-deps",
    "find:selector": "playwright codegen https://www.saucedemo.com/"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Malconb/ui-test-automation-framework.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/Malconb/ui-test-automation-framework/issues"
  },
  "homepage": "https://github.com/Malconb/ui-test-automation-framework#readme",
  "devDependencies": {
    "@cucumber/cucumber": "^12.7.0",
    "@cucumber/pretty-formatter": "^3.2.0",
    "@playwright/test": "^1.51.0",
    "@types/chai": "^5.2.3",
    "@types/mocha": "^10.0.10",
    "@types/node": "^25.4.0",
    "@typescript-eslint/eslint-plugin": "^8.24.0",
    "@typescript-eslint/parser": "^8.24.0",
    "chai": "^6.2.2",
    "dotenv": "^17.3.1",
    "eslint": "^9.20.1",
    "mocha": "^11.7.5",
    "playwright": "^1.51.0",
    "prettier": "^3.8.1",
    "rimraf": "^6.0.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  }
}
